---
import { section } from '@var-ui/core';
import { recipeProps } from '../utils';

type Props = {
  title?: string;
  className?: string;
};

const { title, className } = Astro.props;
const s = section();
const rootProps = recipeProps(s.root, className);
const titleProps = recipeProps(s.title);
---
<section {...rootProps}>
  {title ? <h2 {...titleProps}>{title}</h2> : null}
  <slot />
</section>
