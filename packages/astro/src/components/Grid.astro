---
import { grid } from '@var-ui/core';
import { recipeProps } from '../utils';

type Props = {
  columns?: 'auto' | 1 | 2 | 3 | 4;
  gap?: 'none' | 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  className?: string;
};

const columnVariant = {
  auto: 'auto',
  1: 'one',
  2: 'two',
  3: 'three',
  4: 'four',
} as const;

const { columns = 'auto', gap = 'md', className } = Astro.props;
const rp = recipeProps(grid({ columns: columnVariant[columns], gap }), className);
---
<div {...rp}><slot /></div>
