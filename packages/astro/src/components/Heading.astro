---
import { heading } from '@var-ui/core';
import { recipeProps } from '../utils';

type Props = {
  level?: 1 | 2 | 3 | 4 | 5 | 6;
  size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl' | 'display';
  className?: string;
};

const { level = 2, size = 'md', className } = Astro.props;
const rp = recipeProps(heading({ size }), className);
const HeadingTag = `h${level}` as 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6';
---
<HeadingTag {...rp}><slot /></HeadingTag>
