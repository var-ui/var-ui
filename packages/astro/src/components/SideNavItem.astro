---
import { sideNav } from '@var-ui/core';
import { recipeProps } from '../utils';

type Props = {
  label: string;
  href?: string;
  isSelected?: boolean;
  isDisabled?: boolean;
  className?: string;
};

const {
  label,
  href,
  isSelected = false,
  isDisabled = false,
  className,
} = Astro.props;
const s = sideNav();
const sharedProps = {
  ...recipeProps(s.item, className),
  'data-selected': isSelected || undefined,
  'data-disabled': isDisabled || undefined,
  'aria-current': isSelected ? ('page' as const) : undefined,
};
---

{
  href ? (
    <a href={href} {...sharedProps}>
      <slot name="icon" />
      <span {...recipeProps(s.itemLabel)}>{label}</span>
      {Astro.slots.has('end') ? <slot name="end" /> : null}
    </a>
  ) : (
    <button type="button" disabled={isDisabled} {...sharedProps}>
      <slot name="icon" />
      <span {...recipeProps(s.itemLabel)}>{label}</span>
      {Astro.slots.has('end') ? <slot name="end" /> : null}
    </button>
  )
}
