---
import SideNavSectionHeader from './SideNavSectionHeader.astro';
import { sideNav } from '@var-ui/core';
import Text from './Text.astro';
import { recipeProps } from '../utils';

type Props = {
  title?: string;
  subtitle?: string;
  className?: string;
};

const { title, subtitle, className } = Astro.props;
const s = sideNav();
const hasTitleSlot = Astro.slots.has('title');
const showHeader = hasTitleSlot || title != null || subtitle != null || Astro.slots.has('end');
---

<div {...recipeProps(s.section, className)}>
  {
    showHeader && (
      <div class="side-nav-section__header">
        <div class="side-nav-section__titles">
          {hasTitleSlot ? <slot name="title" /> : title != null ? <SideNavSectionHeader title={title} /> : null}
          {subtitle != null ? (
            <Text as="span" size="sm" tone="secondary">
              {subtitle}
            </Text>
          ) : null}
        </div>
        {Astro.slots.has('end') ? <slot name="end" /> : null}
      </div>
    )
  }
  <slot />
</div>

<style>
  .side-nav-section__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .side-nav-section__titles {
    min-width: 0;
  }
</style>
