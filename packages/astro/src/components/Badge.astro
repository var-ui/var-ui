---
import { badge } from '@var-ui/core';
import { recipeProps } from '../utils';

type Props = {
  tone?: 'neutral' | 'accent' | 'success' | 'warning' | 'danger' | 'tip';
  className?: string;
};

const { tone = 'neutral', className } = Astro.props;
const rp = recipeProps(badge({ tone }), className);
---
<span {...rp}><slot /></span>
