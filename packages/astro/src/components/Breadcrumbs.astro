---
import { breadcrumbs as breadcrumbsStyles } from '@var-ui/core';
import { recipeProps } from '../utils';

type BreadcrumbItemData = {
  id: string;
  label: string;
  href?: string;
};

type Props = {
  items: BreadcrumbItemData[];
  maxItems?: number;
  itemsBeforeCollapse?: number;
  itemsAfterCollapse?: number;
  separator?: string;
  label?: string;
  className?: string;
};

const {
  items,
  maxItems,
  itemsBeforeCollapse = 1,
  itemsAfterCollapse = 1,
  separator,
  label = 'Breadcrumb',
  className,
} = Astro.props;

const ELLIPSIS_ID = '__ellipsis__';

type VisibleItem = BreadcrumbItemData & { isEllipsis?: boolean };

function getVisibleItems(
  allItems: BreadcrumbItemData[],
  max: number | undefined,
  before: number,
  after: number,
): VisibleItem[] {
  if (max == null || allItems.length <= max) {
    return allItems;
  }
  const leadingCount = Math.max(0, Math.min(before, allItems.length));
  const trailingCount = Math.max(0, Math.min(after, allItems.length - leadingCount));
  const leading = allItems.slice(0, leadingCount);
  const trailing = allItems.slice(allItems.length - trailingCount);
  return [...leading, { id: ELLIPSIS_ID, label: '…', isEllipsis: true }, ...trailing];
}

const b = breadcrumbsStyles();
const visibleItems = getVisibleItems(items, maxItems, itemsBeforeCollapse, itemsAfterCollapse);
const style = separator ? `--var-ui-breadcrumbs-separator: "${separator}"` : undefined;
const lastId = items[items.length - 1]?.id;
---

<nav aria-label={label} {...recipeProps(b.root, className)} style={style}>
  <ol {...recipeProps(b.list)}>
    {
      visibleItems.map((item) => {
        const isCurrent = !item.isEllipsis && item.id === lastId;
        if (item.isEllipsis) {
          return (
            <li {...recipeProps(b.ellipsisItem)}>
              <span {...recipeProps(b.link)} data-disabled aria-hidden="true">
                {item.label}
              </span>
            </li>
          );
        }
        return (
          <li {...recipeProps(b.item)} data-current={isCurrent || undefined}>
            {item.href && !isCurrent ? (
              <a href={item.href} {...recipeProps(b.link)}>
                {item.label}
              </a>
            ) : (
              <span {...recipeProps(b.link)} data-disabled={isCurrent || undefined}>
                {item.label}
              </span>
            )}
          </li>
        );
      })
    }
  </ol>
</nav>
