---
import { center } from '@var-ui/core';
import { recipeProps } from '../utils';

type Props = {
  inline?: boolean;
  className?: string;
};

const { inline = false, className } = Astro.props;
const rp = recipeProps(center({ inline: inline ? 'true' : 'false' }), className);
---
<div {...rp}><slot /></div>
