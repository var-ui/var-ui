---
import { card } from '@var-ui/core';
import { recipeProps } from '../utils';

type Props = {
  title?: string;
  className?: string;
};

const { title, className } = Astro.props;
const c = card();
---
<div {...recipeProps(c.root, className)}>
  {title ? <h3 {...recipeProps(c.title)}>{title}</h3> : null}
  <div {...recipeProps(c.body)}><slot /></div>
</div>
