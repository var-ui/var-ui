---
import { icon, segmentedControl, toggleButton } from '@var-ui/core';
import { recipeClassName, recipeProps } from '../utils';

type ColorModeToggleAppearance = 'icons' | 'labels' | 'iconsAndLabels';

type Props = {
  includeSystem?: boolean;
  appearance?: ColorModeToggleAppearance;
  size?: 'sm' | 'md' | 'lg';
  className?: string;
  'aria-label'?: string;
  storageKey?: string;
};

const {
  includeSystem = false,
  appearance = 'icons',
  size = 'md',
  className,
  'aria-label': ariaLabel = 'Color mode',
  storageKey = 'theme-mode',
} = Astro.props;

const modes = (includeSystem ? ['light', 'dark', 'system'] : ['light', 'dark']) as const;
const s = segmentedControl();
const t = toggleButton({ size });
const i = icon({ size: 'md' });
const rootClass = recipeClassName(s.root, className);
const buttonRecipe = recipeProps(t);
const iconRecipe = recipeProps(i);

const MODE_META = {
  light: { label: 'Light', icon: 'colorModeLight' },
  dark: { label: 'Dark', icon: 'colorModeDark' },
  system: { label: 'System', icon: 'colorModeSystem' },
} as const;

const ICON_SVG = {
  colorModeLight:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path></svg>',
  colorModeDark:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"></path></svg>',
  colorModeSystem:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect height="12" rx="1.5" width="18" x="3" y="4"></rect><path d="M8 20h8M12 16v4"></path></svg>',
} as const;
---

<div
  role="group"
  aria-label={ariaLabel}
  class={rootClass}
  data-var-ui-color-mode-toggle
  data-include-system={includeSystem ? 'true' : 'false'}
  data-storage-key={storageKey}
>
  {
    modes.map((mode) => {
      const meta = MODE_META[mode];
      const ariaLabelProp = appearance === 'icons' ? { 'aria-label': meta.label } : {};
      return (
        <button
          type="button"
          data-color-mode={mode}
          aria-pressed="false"
          {...buttonRecipe}
          {...ariaLabelProp}
        >
          {appearance === 'labels' ? (
            meta.label
          ) : appearance === 'iconsAndLabels' ? (
            <>
              <span {...iconRecipe} set:html={ICON_SVG[meta.icon]} />
              {meta.label}
            </>
          ) : (
            <span {...iconRecipe} set:html={ICON_SVG[meta.icon]} />
          )}
        </button>
      );
    })
  }
</div>

<script>
  import { initColorModeToggle } from '../scripts/colorMode';
  initColorModeToggle();
</script>
