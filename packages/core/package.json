{
  "name": "@var-ui/core",
  "version": "0.0.1",
  "description": "Framework-agnostic design tokens and component styles for var-ui",
  "homepage": "https://github.com/var-ui/var-ui/tree/main/packages/core#readme",
  "bugs": "https://github.com/var-ui/var-ui/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/var-ui/var-ui.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./codeHighlight": {
      "types": "./dist/components/codeHighlight.d.mts",
      "import": "./dist/components/codeHighlight.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "pack": "vp pack",
    "dev": "vp pack --watch"
  },
  "dependencies": {
    "typestyles": "catalog:"
  },
  "devDependencies": {
    "@typestyles/cli": "^0.2.1",
    "@typestyles/eslint-plugin": "^0.3.1",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  }
}
