{
  "name": "var-ui-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "vp config",
    "check": "vp check",
    "fmt": "vp fmt",
    "lint": "vp lint",
    "test": "vp test run",
    "build": "vp run -F @var-ui/core -F @var-ui/react -F @var-ui/icons build",
    "pack": "vp run -F @var-ui/core -F @var-ui/react -F @var-ui/icons pack",
    "dev": "vp run @var-ui/example-vite-app#dev",
    "docs:dev": "vp run @var-ui/docs#dev",
    "docs:build": "vp run @var-ui/docs#build",
    "docs:preview": "vp run @var-ui/docs#preview",
    "ready": "vp check && vp test run && vp run -F @var-ui/core -F @var-ui/react -F @var-ui/icons build"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.29.8",
    "@types/node": "^24.0.0",
    "@typestyles/eslint-plugin": "^0.3.0",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@10.11.1"
}
