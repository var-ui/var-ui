{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@var-ui/core": ["../packages/core/src/index.ts"],
      "@var-ui/react": ["../packages/react/src/index.ts"],
      "@var-ui/icons": ["../packages/icons/src/index.ts"],
      "@var-ui/astro": ["../packages/astro/index.ts"],
      "content-collections": ["./.content-collections/generated"]
    }
  },
  "include": [
    "src",
    "astro.config.mjs",
    "content-collections.ts",
    "vite.config.ts",
    "typestyles-entry.ts",
    ".content-collections/generated",
    "scripts"
  ],
  "exclude": ["dist", "node_modules", ".astro"]
}
