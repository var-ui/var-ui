---
import type { ComponentAttrsResult } from 'typestyles';
import { button, commandPalette, kbd } from '@var-ui/core';
import { recipeClassName, recipeProps } from '@var-ui/astro';
import { buildDocsSearchIndex } from '../lib/search-index';

const index = buildDocsSearchIndex();
const indexJson = JSON.stringify(index);

type CommandPaletteSlot =
  | 'root'
  | 'dialog'
  | 'inputRow'
  | 'inputIcon'
  | 'input'
  | 'results'
  | 'resultLink'
  | 'resultLinkActive'
  | 'resultTitle'
  | 'resultMeta'
  | 'empty';
type CommandPaletteSlots = Record<CommandPaletteSlot, ComponentAttrsResult>;
type CommandPaletteRecipeFn = (args?: { open?: boolean }) => CommandPaletteSlots;
const cp = (commandPalette as unknown as CommandPaletteRecipeFn)({ open: false });
const triggerRecipe = recipeProps(button({ intent: 'secondary', size: 'md' }));
const kbdRecipe = recipeProps(kbd());
const rootRecipe = recipeProps(cp.root, 'docs-search__root');
const dialogClass = recipeClassName(cp.dialog);
const inputRowRecipe = recipeProps(cp.inputRow);
const inputIconRecipe = recipeProps(cp.inputIcon);
const inputRecipe = recipeProps(cp.input);
const resultsRecipe = recipeProps(cp.results);
const resultLinkClass = recipeClassName(cp.resultLink);
const resultLinkActiveClass = recipeClassName(cp.resultLinkActive);
const resultTitleClass = recipeClassName(cp.resultTitle);
const resultMetaClass = recipeClassName(cp.resultMeta);
const emptyClass = recipeClassName(cp.empty);
---

<div
  class="docs-search"
  data-docs-search
  data-class-result-link={resultLinkClass}
  data-class-result-link-active={resultLinkActiveClass}
  data-class-result-title={resultTitleClass}
  data-class-result-meta={resultMetaClass}
  data-class-empty={emptyClass}
>
  <button type="button" data-docs-search-open aria-label="Search docs" {...triggerRecipe}>
    <span>Search</span>
    <kbd {...kbdRecipe} aria-hidden="true">⌘K</kbd>
  </button>

  <dialog data-docs-search-dialog aria-label="Search docs">
    <div {...rootRecipe}>
      <div class:list={[dialogClass, 'docs-search__panel']} data-docs-search-panel>
        <div {...inputRowRecipe}>
          <span {...inputIconRecipe} aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
              <circle cx="11" cy="11" r="7"></circle>
              <path d="M16.5 16.5L21 21"></path>
            </svg>
          </span>
          <input
            {...inputRecipe}
            type="search"
            data-docs-search-input
            placeholder="Search docs…"
            autocomplete="off"
            spellcheck="false"
            role="combobox"
            aria-autocomplete="list"
            aria-controls="docs-search-results"
            aria-expanded="true"
          />
        </div>
        <div
          {...resultsRecipe}
          id="docs-search-results"
          data-docs-search-results
          role="listbox"
        >
        </div>
      </div>
    </div>
  </dialog>

  <script is:inline type="application/json" data-docs-search-index set:html={indexJson} />
</div>

<script>
  import { initDocsSearch } from '../scripts/docsSearch';
  initDocsSearch();
</script>

<style>
  .docs-search {
    display: inline-flex;
    align-items: center;
  }

  /* Reset native <dialog> chrome so theme tokens paint the panel, not UA canvas colors. */
  .docs-search [data-docs-search-dialog] {
    border: none;
    margin: 0;
    max-width: none;
    max-height: none;
    width: 100%;
    height: 100%;
    padding: max(12vh, 72px) var(--var-ui-space-4) var(--var-ui-space-5);
    background: transparent;
    color: inherit;
    overflow: visible;
    box-sizing: border-box;
  }

  .docs-search [data-docs-search-dialog]:not([open]) {
    display: none;
  }

  .docs-search [data-docs-search-dialog][open] {
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .docs-search__root {
    position: static;
    inset: auto;
    z-index: auto;
    display: block;
    width: min(640px, 100%);
    padding: 0;
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .docs-search__panel {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-height: min(72vh, 560px);
    opacity: 1;
    border-radius: 0;
    background-color: var(--var-ui-color-background-elevated);
    border: var(--var-ui-borderWidth-default) solid var(--var-ui-color-border-default);
    box-shadow: var(--var-ui-shadow-lg);
  }

  .docs-search :global(.var-ui-command-palette__inputRow) {
    padding: 1rem 1.25rem;
    gap: 0.75rem;
    border-bottom: var(--var-ui-borderWidth-default) solid var(--var-ui-color-border-default);
  }

  .docs-search :global(.var-ui-command-palette__inputIcon) {
    color: var(--var-ui-color-text-secondary);
  }

  .docs-search :global(.var-ui-command-palette__input) {
    font-size: var(--var-ui-fontSize-lg);
    line-height: 1.4;
  }

  .docs-search :global(.var-ui-command-palette__results) {
    padding: 0.375rem 0 0.75rem;
    scrollbar-width: thin;
    scrollbar-color: var(--var-ui-color-border-default) transparent;
  }

  .docs-search :global(.var-ui-command-palette__resultLink) {
    padding: 0.625rem 1.25rem;
    border-left: 2px solid transparent;
  }

  .docs-search :global(.var-ui-command-palette__resultLink:hover),
  .docs-search :global(.var-ui-command-palette__resultLinkActive) {
    background-color: var(--var-ui-color-background-subtle);
    border-left-color: var(--var-ui-color-accent-default);
  }

  .docs-search :global(.var-ui-command-palette__resultTitle) {
    font-size: var(--var-ui-fontSize-md);
    font-weight: var(--var-ui-fontWeight-semibold);
    line-height: 1.35;
    margin-bottom: 0.125rem;
  }

  .docs-search :global(.var-ui-command-palette__resultMeta) {
    font-size: var(--var-ui-fontSize-sm);
    line-height: 1.3;
  }

  .docs-search :global(.var-ui-command-palette__empty) {
    padding: 1.25rem;
    text-align: center;
  }

  /* Result groups are rendered client-side without Astro scope attributes. */
  .docs-search :global(.docs-search__group) {
    padding-top: 0.375rem;
  }

  .docs-search :global(.docs-search__group + .docs-search__group) {
    margin-top: 0.5rem;
    padding-top: 0.625rem;
    border-top: var(--var-ui-borderWidth-default) solid var(--var-ui-color-border-default);
  }

  .docs-search :global(.docs-search__group-label) {
    margin: 0;
    padding: 0.25rem 1.25rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: var(--var-ui-fontWeight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--var-ui-color-text-secondary);
  }

  .docs-search [data-docs-search-dialog]::backdrop {
    background: color-mix(in oklch, var(--var-ui-color-overlay-default) 42%, transparent);
  }

  @supports (backdrop-filter: blur(1px)) {
    .docs-search [data-docs-search-dialog]::backdrop {
      backdrop-filter: blur(14px) saturate(0.85);
    }
  }

  @media (max-width: 768px) {
    .docs-search kbd {
      display: none;
    }
  }
</style>
