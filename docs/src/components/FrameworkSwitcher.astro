---
import { segmentedControl, toggleButton } from '@var-ui/core';
import { recipeClassName, recipeProps } from '@var-ui/astro';
import { DOCS_FRAMEWORKS } from '../lib/framework';
import { FRAMEWORK_META } from '../lib/framework-icons';

const framework = Astro.locals.framework;

const s = segmentedControl();
const t = toggleButton({ size: 'sm' });
const rootClass = recipeClassName(s.root);
const buttonRecipe = recipeProps(t);
---

<div
  class={rootClass}
  role="group"
  aria-label="Documentation framework"
  data-framework-switcher
>
  {
    DOCS_FRAMEWORKS.map((value) => {
      const meta = FRAMEWORK_META[value];
      return (
        <button
          type="button"
          {...buttonRecipe}
          data-framework={value}
          aria-label={meta.label}
          aria-pressed={framework === value ? 'true' : 'false'}
          {...(framework === value ? { 'data-selected': '' } : {})}
          set:html={meta.iconSvg}
        />
      );
    })
  }
</div>

<style>
  [data-framework-switcher] :global(svg) {
    display: block;
    width: 1.125rem;
    height: 1.125rem;
  }
</style>

<script>
  import { initFrameworkSwitcher } from '../scripts/frameworkSwitcher';
  initFrameworkSwitcher();
</script>
