---
import { DOCS_FRAMEWORKS, type DocsFramework } from '../lib/framework';

const framework = Astro.locals.framework;

const labels: Record<DocsFramework, string> = {
  react: 'React',
  astro: 'Astro',
  html: 'HTML',
};
---

<div class="framework-switcher" role="group" aria-label="Documentation framework">
  {
    DOCS_FRAMEWORKS.map((value) => (
      <button
        type="button"
        class="framework-switcher__option"
        data-framework={value}
        aria-pressed={framework === value ? 'true' : 'false'}
      >
        {labels[value]}
      </button>
    ))
  }
</div>

<script>
  import { applyFrameworkChoice } from '../scripts/frameworkSwitcher';
  import type { DocsFramework } from '../lib/framework';

  const root = document.currentScript?.previousElementSibling;
  if (root instanceof HTMLElement) {
    root.addEventListener('click', (event) => {
      const target = (event.target as HTMLElement | null)?.closest('[data-framework]');
      if (!(target instanceof HTMLElement)) return;
      const framework = target.dataset.framework as DocsFramework | undefined;
      if (framework) applyFrameworkChoice(framework);
    });
  }
</script>

<style>
  .framework-switcher {
    display: inline-flex;
    gap: 0.25rem;
  }

  .framework-switcher__option {
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--color-border, #ccc);
    border-radius: 0.375rem;
    background: transparent;
    cursor: pointer;
    font: inherit;
  }

  .framework-switcher__option[aria-pressed='true'] {
    background: var(--color-accent, #333);
    color: var(--color-accent-foreground, #fff);
    border-color: transparent;
  }
</style>
