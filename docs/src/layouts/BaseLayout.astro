---
import { ThemeScript, ColorModeToggle } from '@var-ui/astro';
import { defaultTheme } from '@var-ui/core';
import DocsSearch from '../components/DocsSearch.astro';
import FrameworkSwitcher from '../components/FrameworkSwitcher.astro';
import { topNav } from '../data/navigation';

const { title = 'Var UI' } = Astro.props;
const framework = Astro.locals.framework;
const pathname = Astro.url.pathname;
---

<html lang="en" class={defaultTheme.className} data-framework={framework}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <ThemeScript themeClass={defaultTheme.className} />
    <link rel="stylesheet" href="/typestyles.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__brand">
        <a class="site-logo" href="/">Var UI</a>
        <nav class="site-nav" aria-label="Primary">
          {
            topNav.map((item) => (
              <a
                href={item.link}
                aria-current={pathname.startsWith(item.match) ? 'page' : undefined}
              >
                {item.text}
              </a>
            ))
          }
        </nav>
      </div>
      <div class="site-header__tools">
        <DocsSearch />
        <FrameworkSwitcher />
        <ColorModeToggle includeSystem appearance="labels" />
      </div>
    </header>
    <main class="site-main">
      <slot />
    </main>
  </body>
</html>

<style>
  .site-header {
    padding: 1rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .site-header__brand {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .site-logo {
    font-weight: 650;
    text-decoration: none;
    color: inherit;
  }

  .site-nav {
    display: flex;
    gap: 0.75rem;
  }

  .site-nav a {
    text-decoration: none;
    color: inherit;
    opacity: 0.75;
  }

  .site-nav a[aria-current='page'] {
    opacity: 1;
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .site-header__tools {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .site-main {
    padding: 0 1.5rem 3rem;
    max-width: 960px;
    margin: 0 auto;
  }
</style>
