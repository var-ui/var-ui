---
import {
  AppShell,
  ColorModeToggle,
  MobileNav,
  MobileNavToggle,
  SideNav,
  ThemeScript,
  TopNav,
  TopNavHeading,
  TopNavItem,
} from '@var-ui/astro';
import { defaultTheme } from '@var-ui/core';
import DocsSearch from '../components/DocsSearch.astro';
import DocsSidebarNav from '../components/DocsSidebarNav.astro';
import FrameworkSwitcher from '../components/FrameworkSwitcher.astro';
import {
  componentSidebarSections,
  themingSidebarSections,
  topNav as topNavItems,
} from '../data/navigation';

const { title = 'Var UI' } = Astro.props;
const framework = Astro.locals.framework;
const pathname = Astro.url.pathname;

function normalizePath(path: string): string {
  return path.endsWith('/') && path.length > 1 ? path.slice(0, -1) : path;
}

const currentPath = normalizePath(pathname);

const sidebarSections = currentPath.startsWith('/components')
  ? componentSidebarSections
  : currentPath.startsWith('/theming')
    ? themingSidebarSections
    : null;

function isSidebarLinkActive(link: string): boolean {
  return currentPath === normalizePath(link);
}
---

<html lang="en" class={defaultTheme.className} data-framework={framework}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <ThemeScript themeClass={defaultTheme.className} />
    <link rel="stylesheet" href="/typestyles.css" />
  </head>
  <body class="docs-body">
    <AppShell variant="wash" height="fill" contentPadding={6} mobileBreakpoint="md">
      <TopNav slot="topNav">
        <TopNavHeading slot="heading" heading="Var UI" headingHref="/" />
        {
          topNavItems.map((item) => (
            <TopNavItem
              label={item.text}
              href={item.link}
              isSelected={currentPath.startsWith(item.match)}
            />
          ))
        }
        <div slot="end" class="docs-top-nav__tools">
          {sidebarSections ? <MobileNavToggle /> : null}
          <DocsSearch />
          <FrameworkSwitcher />
          <ColorModeToggle includeSystem size="sm" />
        </div>
      </TopNav>

      {
        sidebarSections && (
          <SideNav
            slot="sideNav"
            label="Section"
            collapsible
            resizable={{ autoSaveId: 'docs-sidebar' }}
          >
            <DocsSidebarNav sections={sidebarSections} isLinkActive={isSidebarLinkActive} />
          </SideNav>
        )
      }

      {
        sidebarSections && (
          <MobileNav slot="mobileNav" header="Menu">
            <DocsSidebarNav sections={sidebarSections} isLinkActive={isSidebarLinkActive} />
          </MobileNav>
        )
      }

      <div class="docs-content">
        <slot />
      </div>
    </AppShell>
  </body>
</html>

<style is:global>
  html,
  body.docs-body {
    height: 100%;
    margin: 0;
  }

  body.docs-body {
    overflow: hidden;
  }
</style>

<style>
  .docs-top-nav__tools {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .docs-content {
    max-width: 60rem;
    margin: 0 auto;
    padding-bottom: 3rem;
  }
</style>
