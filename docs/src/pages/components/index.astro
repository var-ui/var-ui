---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { componentSidebar } from '../../data/navigation';
import { findMdxModule } from '../../lib/loadMdx';

const modules = import.meta.glob('../../../content/components/*.mdx');
const loader = findMdxModule(modules, 'index');
if (!loader) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const { Content, frontmatter } = await loader();
---

<BaseLayout title={`${frontmatter.title} · Var UI`}>
  <article class="docs-article">
    <Content />
    <h2>All components</h2>
    <ul class="component-list">
      {componentSidebar.map((item) => (
        <li>
          <a href={item.link}>{item.text}</a>
        </li>
      ))}
    </ul>
  </article>
</BaseLayout>

<style>
  .docs-article {
    max-width: 48rem;
  }

  .docs-article :global(h1) {
    margin-block: 0 0.5rem;
    font-size: 2rem;
    line-height: 1.2;
  }

  .docs-article :global(h2) {
    margin-block: 2rem 0.75rem;
    font-size: 1.35rem;
  }

  .docs-article :global(p) {
    margin-block: 0.75rem;
    line-height: 1.6;
  }

  .component-list {
    margin: 0;
    padding: 0;
    list-style: none;
    columns: 2;
    column-gap: 2rem;
  }

  .component-list li {
    margin-block: 0.35rem;
  }

  .component-list a {
    color: inherit;
  }
</style>
