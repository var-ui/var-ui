---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import DemoHost from '../../components/DemoHost.astro';
import { DEMO_IDS } from '../../demos/registry';
---

<BaseLayout title="DemoHost smoke">
  <h1>DemoHost smoke</h1>
  <p>Temporary Task 5 page — switch frameworks and confirm one preview path per request.</p>
  {
    DEMO_IDS.map((id) => (
      <section>
        <h2>{id}</h2>
        <DemoHost id={id} />
      </section>
    ))
  }
</BaseLayout>
