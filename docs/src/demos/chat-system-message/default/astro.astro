---
import { chatSystemMessage } from '@var-ui/core';
import { recipeProps } from '../../../lib/recipeProps';

// No @var-ui/astro ChatSystemMessage — core recipe markup.
const info = chatSystemMessage({ tone: 'info' });
const success = chatSystemMessage({ tone: 'success' });
---

<div {...recipeProps(info.root)} role="status">
  <span {...recipeProps(info.text)}>Model switched to GPT-5</span>
</div>
<div {...recipeProps(success.root)} role="status">
  <span {...recipeProps(success.text)}>Alex joined the conversation</span>
</div>
