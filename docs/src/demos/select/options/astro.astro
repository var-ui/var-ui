---
import { grid, select } from '@var-ui/core';
import { recipeProps } from '../../../lib/recipeProps';

const g = grid({ columns: 'two', gap: 'lg' });
const s = select();
const options = [
  { id: 'apple', label: 'Apple' },
  { id: 'plum', label: 'Plum' },
  { id: 'orange', label: 'Orange' },
  { id: 'grape', label: 'Grape' },
];
---

<div {...recipeProps(g)}>
  <div {...recipeProps(s.root)}>
    <label {...recipeProps(s.label)} for="fruit-options">Fruit</label>
    <select {...recipeProps(s.trigger)} id="fruit-options">
      <option value="" disabled selected>Select…</option>
      {options.map((option) => <option value={option.id}>{option.label}</option>)}
    </select>
  </div>
  <div {...recipeProps(s.root)}>
    <label {...recipeProps(s.label)} for="favorite-fruit">Favorite fruit</label>
    <select {...recipeProps(s.trigger)} id="favorite-fruit">
      <option value="" disabled selected>Choose a fruit…</option>
      {options.map((option) => <option value={option.id}>{option.label}</option>)}
    </select>
  </div>
</div>
