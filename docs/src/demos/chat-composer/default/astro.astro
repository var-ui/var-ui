---
import { button, chatComposer } from '@var-ui/core';
import { recipeProps } from '../../../lib/recipeProps';

// No @var-ui/astro ChatComposer — static core-recipe chrome (non-interactive).
const c = chatComposer();
const send = button({ intent: 'primary' });
---

<div {...recipeProps(c.root)}>
  <div {...recipeProps(c.inputRow)}>
    <textarea
      {...recipeProps(c.input)}
      rows="1"
      placeholder="Type a message…"
      aria-label="Message"
      disabled></textarea
    >
  </div>
  <div {...recipeProps(c.actions)}>
    <button type="button" {...recipeProps(send)} aria-label="Send message" disabled>
      <svg
        viewBox="0 0 24 24"
        width="16"
        height="16"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M12 19V5M5 12l7-7 7 7"></path>
      </svg>
    </button>
  </div>
</div>
