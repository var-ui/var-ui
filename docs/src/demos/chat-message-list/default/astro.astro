---
import { chatMessage, chatMessageBubble, chatMessageList } from '@var-ui/core';
import { recipeProps } from '../../../lib/recipeProps';

// No @var-ui/astro ChatMessageList — core recipe log region.
const l = chatMessageList({ density: 'balanced' });
const assistant = chatMessage({ sender: 'assistant' });
const user = chatMessage({ sender: 'user' });
const assistantBubble = chatMessageBubble({
  sender: 'assistant',
  variant: 'filled',
  group: 'none',
});
const userBubble = chatMessageBubble({ sender: 'user', variant: 'filled', group: 'none' });
---

<div {...recipeProps(l.root)} role="log" aria-live="polite">
  <div {...recipeProps(l.inner)}>
    <div {...recipeProps(assistant.root)}>
      <div {...recipeProps(assistant.content)}>
        <div {...recipeProps(assistantBubble.root)}>Hello! How can I help?</div>
      </div>
    </div>
    <div {...recipeProps(user.root)}>
      <div {...recipeProps(user.content)}>
        <div {...recipeProps(userBubble.root)}>What components ship in var-ui?</div>
      </div>
    </div>
  </div>
</div>
