---
import { Tabs, Text } from '@var-ui/astro';

const tabDefs = [
  { id: 'overview', label: 'Overview' },
  { id: 'details', label: 'Details' },
];
---

<Tabs tabs={tabDefs} defaultSelectedId="overview">
  <div slot="overview">
    <Text>First panel content.</Text>
  </div>
  <div slot="details">
    <Text>Second panel content.</Text>
  </div>
</Tabs>
