---
import { card, carousel } from '@var-ui/core';
import { recipeProps } from '../../../lib/recipeProps';

const s = carousel();
const c = card();

const slides = [
  { title: 'Default', body: 'Scroll-snap slide.' },
  { title: 'Forest', body: 'Scroll-snap slide.' },
  { title: 'Rose', body: 'Scroll-snap slide.' },
];
---

<section {...recipeProps(s.root)} role="region" aria-label="Featured themes">
  <div
    {...recipeProps(s.viewport)}
    data-carousel-viewport
    tabindex="0"
    style="grid-auto-columns: 220px"
  >
    {
      slides.map((slide) => (
        <div {...recipeProps(s.item)} data-carousel-item>
          <div {...recipeProps(c.root)}>
            <h3 {...recipeProps(c.title)}>{slide.title}</h3>
            <div {...recipeProps(c.body)}>{slide.body}</div>
          </div>
        </div>
      ))
    }
  </div>
  <div {...recipeProps(s.controls)}>
    <button type="button" {...recipeProps(s.control)} aria-label="Previous" disabled>
      <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="currentColor">
        <path d="M15 6l-6 6 6 6"></path>
      </svg>
    </button>
    <button type="button" {...recipeProps(s.control)} aria-label="Next" disabled>
      <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="currentColor">
        <path d="M9 6l6 6-6 6"></path>
      </svg>
    </button>
  </div>
</section>
