---
import { button, dialog } from '@var-ui/core';
import { recipeProps } from '../../../lib/recipeProps';

const d = dialog();
const trigger = button({ intent: 'secondary' });
const closeAction = button({});
---

<div style="display: grid; gap: 1rem">
  <button type="button" {...recipeProps(trigger)} disabled>Open dialog</button>
  <!-- No @var-ui/astro Dialog — static core-recipe chrome (open state, non-interactive). -->
  <div
    {...recipeProps(d.overlay)}
    style="position: relative; inset: auto; min-height: 220px"
  >
    <div {...recipeProps(d.modal)} role="dialog" aria-labelledby="dialog-demo-title" aria-modal="true">
      <div {...recipeProps(d.content)}>
        <div {...recipeProps(d.header)}>
          <h2 id="dialog-demo-title" {...recipeProps(d.heading)}>Icon close button</h2>
          <button type="button" {...recipeProps(d.closeButton)} aria-label="Close" disabled>
            <svg
              viewBox="0 0 24 24"
              width="16"
              height="16"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M6 6l12 12M18 6L6 18"></path>
            </svg>
          </button>
        </div>
        <p {...recipeProps(d.description)}>The dismiss control now uses the registry close glyph.</p>
        <button type="button" {...recipeProps(closeAction)} disabled>Close</button>
      </div>
    </div>
  </div>
</div>
