---
import { chatMessage, chatMessageBubble } from '@var-ui/core';
import { recipeProps } from '../../../lib/recipeProps';

// No @var-ui/astro ChatMessageBubble — core recipe markup with group corners.
const m = chatMessage({ sender: 'assistant' });
const first = chatMessageBubble({ sender: 'assistant', variant: 'filled', group: 'first' });
const last = chatMessageBubble({ sender: 'assistant', variant: 'filled', group: 'last' });
---

<div {...recipeProps(m.root)}>
  <div {...recipeProps(m.content)}>
    <div {...recipeProps(m.header)}>
      <span {...recipeProps(m.name)}>Navi</span>
    </div>
    <div {...recipeProps(first.root)}>First part of a multi-part reply.</div>
    <div {...recipeProps(last.root)}>Second part.</div>
  </div>
</div>
