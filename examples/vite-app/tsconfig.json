{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@var-ui/core": ["./../../packages/core/src/index.ts"],
      "@var-ui/react": ["./../../packages/react/src/index.ts"],
      "@var-ui/icons": ["./../../packages/icons/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
